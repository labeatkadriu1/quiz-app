{
  "name": "@quiz/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "migrate": "PRISMA_ENGINES_CACHE_DIR=./.prisma prisma migrate deploy",
    "prisma:generate": "PRISMA_ENGINES_CACHE_DIR=./.prisma prisma generate",
    "prisma:migrate": "PRISMA_ENGINES_CACHE_DIR=./.prisma prisma migrate dev",
    "lint": "echo 'lint not configured yet'",
    "test": "echo 'tests not configured yet'"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.8",
    "@prisma/client": "^5.20.0",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.9",
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
